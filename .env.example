# ── LLM API Keys ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── Supabase (cloud) ─────────────────────────────────────────────────
# Use these for production; docker-compose uses local Postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Local Postgres (docker-compose only) ────────────────────────────
POSTGRES_USER=eval_user
POSTGRES_PASSWORD=eval_pass
POSTGRES_DB=eval_db
DATABASE_URL=postgresql+asyncpg://eval_user:eval_pass@localhost:5432/eval_db

# ── JWT (local PostgREST / Supabase emulation) ───────────────────────
SUPABASE_JWT_SECRET=super-secret-jwt-token-for-local-dev

# ── App config ───────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
BOOTSTRAP_ITERATIONS=1000        # CI resamples; reduce to 100 for speed in dev
CI_HALLUCINATION_THRESHOLD=0.15  # Fail PR if hallucination rate exceeds 15%
CI_ACCURACY_DROP_THRESHOLD=0.02  # Fail PR if accuracy drops more than 2 pp
JUDGE_MODEL=gpt-4o               # Model used as evaluator — never the same as tested model
